# Praxis Engine Configuration
# Copy to .env and fill in your values

# Required — PostgreSQL connection. May point at host-local Postgres, a LAN
# database host, or any reachable Postgres 16+ instance with pgvector.
WORKFLOW_DATABASE_URL=postgresql://nate@localhost:5432/praxis

# Docker worker portability. Compose defaults PRAXIS_CLI_AUTH_HOME to $HOME
# when unset; set it explicitly when the host auth files live elsewhere.
# PRAXIS_CLI_AUTH_HOME=/Users/you
# Worker concurrency is resource-derived when unset. Set only to force a cap.
# PRAXIS_WORKER_MAX_PARALLEL=4
# PRAXIS_WORKFLOW_MAX_CONCURRENT_NODES=4
PRAXIS_WORKFLOW_MCP_URL=http://host.docker.internal:8420/mcp
# Required for worker-launched MCP session tokens. Generate a local value with:
# openssl rand -hex 32
PRAXIS_WORKFLOW_MCP_SIGNING_SECRET=

# LLM Providers — at least one required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Server (optional — defaults shown)
PRAXIS_API_PORT=8420
PRAXIS_API_HOST=0.0.0.0

# Docker sandbox (optional)
PRAXIS_DOCKER_IMAGE=praxis-worker:latest
PRAXIS_DOCKER_MEMORY=4g
PRAXIS_DOCKER_CPUS=2

# Integrations (optional)
GITHUB_TOKEN=
BRAVE_SEARCH_API_KEY=
