#!/usr/bin/env bash
# Start the Praxis API bound to the Tailscale interface with the operator
# console enabled. Verifies Tailscale is installed and authenticated first.
#
# See: docs/runbooks/operator_console_tailscale.md

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

fail() { printf '  \033[1;31m[fail]\033[0m %s\n' "$*" >&2; exit 1; }
ok()   { printf '  \033[1;32m[ok]\033[0m %s\n' "$*"; }
warn() { printf '  \033[1;33m[warn]\033[0m %s\n' "$*"; }
step() { printf '\n\033[1;36m==> %s\033[0m\n' "$*"; }

# --- Tailscale checks --------------------------------------------------------
step "Verifying Tailscale"

if ! command -v tailscale >/dev/null 2>&1; then
  fail "tailscale not on PATH. Install: brew install tailscale (macOS) or curl -fsSL https://tailscale.com/install.sh | sh (Linux). See docs/runbooks/operator_console_tailscale.md."
fi
ok "tailscale at $(command -v tailscale)"

if ! tailscale status >/dev/null 2>&1; then
  fail "tailscale is not running or not authenticated. Run: sudo tailscale up (and sign in via the printed URL). Then rerun."
fi
ok "tailscale authenticated"

tailnet_ip="$(tailscale ip -4 2>/dev/null | head -n1 | tr -d '[:space:]')"
if [ -z "$tailnet_ip" ]; then
  fail "could not read tailnet IPv4 from 'tailscale ip -4'. Is this node in the tailnet?"
fi
ok "tailnet IPv4: $tailnet_ip"

# --- Token + gate ------------------------------------------------------------
step "Checking operator console preconditions"

if [ -z "${PRAXIS_API_TOKEN:-}" ]; then
  fail "PRAXIS_API_TOKEN is not set. The console gate requires a bearer token. Export one before running, e.g. PRAXIS_API_TOKEN=\"\$(openssl rand -hex 32)\"."
fi
ok "PRAXIS_API_TOKEN is set (length ${#PRAXIS_API_TOKEN})"

api_port="${PRAXIS_API_PORT:-8420}"
ok "binding API to ${tailnet_ip}:${api_port}"

# --- Start the API bound to the tailnet interface ----------------------------
step "Starting API with operator console enabled"

venv_python="${repo_root}/.venv/bin/python"
if [ ! -x "$venv_python" ]; then
  fail ".venv not present. Run ./scripts/bootstrap first."
fi

workflow_root="${repo_root}/Code&DBs/Workflow"
if [ ! -d "$workflow_root" ]; then
  fail "workflow root missing at ${workflow_root}"
fi

cat <<INFO

Console URL on the phone (with Tailscale active):
  http://${tailnet_ip}:${api_port}/console

The console gate accepts the same PRAXIS_API_TOKEN you exported.
Stop with Ctrl+C. Logs print to this terminal.

INFO

exec env \
  PRAXIS_OPERATOR_DEV_MODE=1 \
  PRAXIS_API_HOST="${tailnet_ip}" \
  PRAXIS_API_PORT="${api_port}" \
  PYTHONPATH="${workflow_root}${PYTHONPATH:+:$PYTHONPATH}" \
  "$venv_python" -m surfaces.api.server \
    --host "${tailnet_ip}" \
    --port "${api_port}"
