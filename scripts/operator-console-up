#!/usr/bin/env bash
# Start the Praxis API with the operator console enabled.
#
# Default mode is phone-friendly: bind to the Tailscale interface and print
# the URL + access code to paste into the console.
#
# Local-only mode for testing on this computer:
#   ./scripts/operator-console-up --local
#
# Service mode is used by scripts/operator-console:
#   ./scripts/operator-console-up --service
#
# See: docs/runbooks/operator_console_tailscale.md

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

fail() { printf '  \033[1;31m[fail]\033[0m %s\n' "$*" >&2; exit 1; }
ok()   { printf '  \033[1;32m[ok]\033[0m %s\n' "$*"; }
warn() { printf '  \033[1;33m[warn]\033[0m %s\n' "$*" >&2; }
step() { printf '\n\033[1;36m==> %s\033[0m\n' "$*"; }

usage() {
  cat <<'USAGE'
Start the Praxis phone console.

Phone over Tailscale:
  ./scripts/operator-console-up

Same computer only:
  ./scripts/operator-console-up --local

Then open the URL printed by the script and paste the printed access code.
Stop the server with Ctrl+C.
USAGE
}

bind_mode="tailscale"
service_mode="0"
case "${1:-}" in
  "")
    ;;
  "--local")
    bind_mode="local"
    ;;
  "--service")
    bind_mode="tailscale"
    service_mode="1"
    ;;
  "-h"|"--help")
    usage
    exit 0
    ;;
  *)
    usage >&2
    fail "unknown option: $1"
    ;;
esac

state_dir="${repo_root}/artifacts/operator-console"
token_file="${state_dir}/token"
state_file="${state_dir}/state.env"
log_dir="${state_dir}/logs"
mkdir -p "$state_dir" "$log_dir"
chmod 700 "$state_dir" 2>/dev/null || true

port_is_busy() {
  lsof -nP -iTCP:"$1" -sTCP:LISTEN >/dev/null 2>&1
}

pick_api_port() {
  local requested="${PRAXIS_API_PORT:-8420}"
  if ! port_is_busy "$requested"; then
    printf '%s\n' "$requested"
    return 0
  fi
  warn "port ${requested} is already in use; choosing another port"
  local candidate
  for candidate in $(seq 8421 8435); do
    if ! port_is_busy "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  fail "could not find a free port between 8420 and 8435"
}

api_port="$(pick_api_port)"

if [ "$bind_mode" = "local" ]; then
  step "Preparing local console"
  bind_host="127.0.0.1"
  console_url="http://${bind_host}:${api_port}/console"
  ok "local URL: ${console_url}"
else
  # --- Tailscale checks ------------------------------------------------------
  step "Preparing phone console over Tailscale"

  if ! command -v tailscale >/dev/null 2>&1; then
    cat <<'HELP' >&2

Tailscale is what lets your phone reach Praxis privately.

If you only want to test on this computer, run:
  ./scripts/operator-console-up --local

For phone access:
  1. Install/open Tailscale on this computer.
  2. Install/open Tailscale on your phone.
  3. Sign into both with the same account.
  4. Run this command again.

HELP
    fail "Tailscale is not installed."
  fi
  ok "tailscale found"

  if [ "$service_mode" = "1" ]; then
    for _ in $(seq 1 60); do
      if tailscale status >/dev/null 2>&1; then
        break
      fi
      sleep 2
    done
  fi

  if ! tailscale status >/dev/null 2>&1; then
    cat <<'HELP' >&2

Tailscale is installed but not connected.

Open Tailscale, sign in, then run:
  ./scripts/operator-console-up

For local-only testing, run:
  ./scripts/operator-console-up --local

HELP
    fail "Tailscale is not running or not authenticated."
  fi
  ok "tailscale connected"

  tailnet_ip="$(tailscale ip -4 2>/dev/null | head -n1 | tr -d '[:space:]')"
  if [ -z "$tailnet_ip" ]; then
    fail "could not read the Tailscale IP. Open Tailscale and confirm this computer is connected."
  fi
  bind_host="0.0.0.0"
  public_host="$tailnet_ip"
  console_url="http://${public_host}:${api_port}/console"
  tailnet_dns="$(
    tailscale status --json 2>/dev/null | python3 -c 'import json,sys; payload=json.load(sys.stdin); dns=((payload.get("Self") or {}).get("DNSName") or "").strip().rstrip("."); print(dns) if dns else None' 2>/dev/null || true
  )"
  if [ -n "$tailnet_dns" ] && tailscale serve --bg --yes "http://127.0.0.1:${api_port}" >/dev/null 2>&1; then
    console_url="https://${tailnet_dns}/console"
    ok "secure phone URL: ${console_url}"
  else
    ok "phone URL: ${console_url}"
    warn "HTTPS Tailscale Serve was unavailable; notifications may need a secure URL"
  fi
fi

# --- Token + gate ------------------------------------------------------------
step "Preparing access code"

if [ -z "${PRAXIS_API_TOKEN:-}" ]; then
  if [ -r "$token_file" ]; then
    PRAXIS_API_TOKEN="$(tr -d '[:space:]' < "$token_file")"
    export PRAXIS_API_TOKEN
    ok "using saved access code"
  else
    if command -v openssl >/dev/null 2>&1; then
      PRAXIS_API_TOKEN="$(openssl rand -hex 16)"
    else
      PRAXIS_API_TOKEN="$("$repo_root/.venv/bin/python" - <<'PY'
import secrets
print(secrets.token_hex(16))
PY
)"
    fi
    export PRAXIS_API_TOKEN
    printf '%s\n' "$PRAXIS_API_TOKEN" > "$token_file"
    chmod 600 "$token_file" 2>/dev/null || true
    ok "created and saved a new access code"
  fi
else
  printf '%s\n' "$PRAXIS_API_TOKEN" > "$token_file"
  chmod 600 "$token_file" 2>/dev/null || true
  ok "using existing access code"
fi

# --- Start the API bound to the tailnet interface ----------------------------
step "Starting API with operator console enabled"

venv_python="${repo_root}/.venv/bin/python"
if [ ! -x "$venv_python" ]; then
  fail ".venv not present. Run ./scripts/bootstrap first."
fi

workflow_root="${repo_root}/Code&DBs/Workflow"
if [ ! -d "$workflow_root" ]; then
  fail "workflow root missing at ${workflow_root}"
fi

cat > "$state_file" <<STATE
CONSOLE_URL='${console_url}'
PRAXIS_API_TOKEN='${PRAXIS_API_TOKEN}'
PRAXIS_API_HOST='${public_host:-$bind_host}'
PRAXIS_API_BIND='${bind_host}'
PRAXIS_API_PORT='${api_port}'
STATE
chmod 600 "$state_file" 2>/dev/null || true

cat <<INFO

Open this URL:
  ${console_url}

No sign-in code required. Tailscale is the gate.

Stop with Ctrl+C. Logs print to this terminal.

INFO

exec env \
  PRAXIS_OPERATOR_DEV_MODE=1 \
  PRAXIS_OPERATOR_TRUST_TAILSCALE=1 \
  PRAXIS_API_TOKEN="${PRAXIS_API_TOKEN}" \
  PRAXIS_API_HOST="${bind_host}" \
  PRAXIS_API_PORT="${api_port}" \
  PYTHONPATH="${workflow_root}${PYTHONPATH:+:$PYTHONPATH}" \
  "$venv_python" -m surfaces.api.server \
    --host "${bind_host}" \
    --port "${api_port}"
