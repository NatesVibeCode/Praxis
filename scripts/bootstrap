#!/usr/bin/env bash
# Praxis fresh-clone bootstrap.
#
# Takes a fresh clone from zero to a verified native install in one command:
#   1. Resolve a repo-local database authority, creating .env when absent.
#   2. Create the target Postgres database and enable pgvector.
#   3. Create .venv and install requirements.runtime.txt.
#   4. Install a config-backed Praxis runtime launcher onto PATH.
#   5. Run DB bootstrap and fresh-install seed via the native operator surface.
#   6. Start the REST API on PRAXIS_API_PORT.
#   7. Validate, submit, and stream examples/bootstrap_smoke.queue.json.
#
# Idempotent: re-running on a healthy install preserves existing authority.
# Roadmap: roadmap_item.fresh.instance.onboarding.readiness.bootstrap.one.command.fresh.clone

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
# shellcheck source=./_workflow_env.sh
source "$repo_root/scripts/_workflow_env.sh"
workflow_root="$(workflow_repo_workflow_root)"

step() { printf '\n\033[1;36m==> %s\033[0m\n' "$*"; }
ok()   { printf '  \033[1;32m[ok]\033[0m %s\n' "$*"; }
warn() { printf '  \033[1;33m[warn]\033[0m %s\n' "$*"; }
die()  { printf '  \033[1;31m[fail]\033[0m %s\n' "$*" >&2; exit 1; }

redact_url_for_log() {
  local raw_url="$1"
  PYTHONPATH="$workflow_root${PYTHONPATH:+:$PYTHONPATH}" "$python_bin" - "$raw_url" <<'PY' || printf '<redacted-url>\n'
import sys
from runtime.primitive_contracts import redact_url

print(redact_url(sys.argv[1]) or "")
PY
}

without_contract_env() {
  env -u WORKFLOW_DATABASE_URL -u WORKFLOW_DATABASE_AUTHORITY_SOURCE "$@"
}

require_gate() {
  local gate_ref="$1"
  REPO_ROOT="$repo_root" \
    PRAXIS_ONBOARDING_REPO_ROOT="$repo_root" \
    PYTHONPATH="$workflow_root${PYTHONPATH:+:$PYTHONPATH}" \
    "$python_bin" -m runtime.onboarding.bootstrap_cli require "$gate_ref"
}

apply_gate() {
  local gate_ref="$1"
  shift
  REPO_ROOT="$repo_root" \
    PRAXIS_ONBOARDING_REPO_ROOT="$repo_root" \
    PYTHONPATH="$workflow_root${PYTHONPATH:+:$PYTHONPATH}" \
    "$python_bin" -m runtime.onboarding.bootstrap_cli apply-gate "$gate_ref" "$@"
}

ensure_repo_env_file() {
  local resolved_database_url="${1:-}"
  if [ -z "$resolved_database_url" ]; then
    die "could not determine WORKFLOW_DATABASE_URL for .env creation"
  fi
  WORKFLOW_DATABASE_URL="$resolved_database_url" \
    PRAXIS_API_PORT="${PRAXIS_API_PORT:-8420}" \
    apply_gate runtime.env_file --yes >/dev/null || exit 1
  ok ".env declares WORKFLOW_DATABASE_URL=$(redact_url_for_log "$resolved_database_url")"
}

resolve_database_authority() {
  REPO_ROOT="$repo_root" \
    PYTHONPATH="$workflow_root${PYTHONPATH:+:$PYTHONPATH}" \
    "$python_bin" - <<'PY'
import json
import os
import sys
from pathlib import Path

from surfaces._workflow_database import workflow_database_authority_for_repo

try:
    authority = workflow_database_authority_for_repo(
        Path(os.environ["REPO_ROOT"]),
        env=os.environ,
    )
except Exception as exc:
    sys.stderr.write(f"{type(exc).__name__}: {exc}\n")
    raise SystemExit(1)

print(authority.database_url)
print(authority.source)
PY
}

parse_database_authority() {
  WORKFLOW_DATABASE_URL="$database_url" "$python_bin" - <<'PY'
import os
from urllib.parse import urlsplit, urlunsplit

database_url = os.environ["WORKFLOW_DATABASE_URL"]
parts = urlsplit(database_url)
database_name = parts.path.lstrip("/") or "praxis"
maintenance_url = urlunsplit((parts.scheme, parts.netloc, "/postgres", parts.query, parts.fragment))
print(database_name)
print(maintenance_url)
PY
}

probe_api() {
  local url="$1"
  "$python_bin" - "$url" <<'PY' >/dev/null 2>&1
import sys
from urllib.request import urlopen

try:
    with urlopen(sys.argv[1], timeout=2) as response:
        raise SystemExit(0 if 200 <= response.status < 500 else 1)
except Exception:
    raise SystemExit(1)
PY
}

launcher_config_path() {
  if [ -n "${PRAXIS_LAUNCHER_CONFIG:-}" ]; then
    printf '%s\n' "$PRAXIS_LAUNCHER_CONFIG"
    return 0
  fi
  printf '%s\n' "$HOME/.config/praxis/launcher.json"
}

write_launcher_seed_config() {
  local config_path="$1"
  local launcher_api_url="${PRAXIS_API_URL:-}"
  PYTHONPATH="$workflow_root${PYTHONPATH:+:$PYTHONPATH}" \
    "$venv_dir/bin/python" - "$config_path" "$database_url" "$repo_root" "$launcher_api_url" <<'PY'
import sys
from runtime.launcher_authority import write_launcher_seed_config

config_path, database_url, repo_root, api_url = sys.argv[1:5]
write_launcher_seed_config(
    config_path,
    workspace_ref="praxis",
    host_ref="default",
    api_url=api_url or None,
    database_url=database_url,
    environment={"PRAXIS_WORKSPACE_BASE_PATH": repo_root},
)
PY
}

target_is_managed_launcher() {
  local target="$1"
  [ -f "$target" ] && grep -q "Praxis runtime launcher. Managed by ./scripts/bootstrap." "$target"
}

target_is_legacy_sql_locator() {
  local target="$1"
  [ -f "$target" ] || return 1
  PYTHONPATH="$workflow_root${PYTHONPATH:+:$PYTHONPATH}" \
    "$venv_dir/bin/python" - "$target" <<'PY'
import sys
from pathlib import Path
from runtime.launcher_authority import looks_like_legacy_sql_locator

path = Path(sys.argv[1])
raise SystemExit(0 if looks_like_legacy_sql_locator(path.read_text(encoding="utf-8")) else 1)
PY
}

install_runtime_launcher() {
  local target="$1"
  local backup=""
  if [ -e "$target" ] || [ -L "$target" ]; then
    if target_is_managed_launcher "$target"; then
      ok "updating managed praxis runtime launcher at $target"
    else
      backup="${target}.backup.$(date +%Y%m%d%H%M%S)"
      if target_is_legacy_sql_locator "$target"; then
        warn "old SQL locator shim detected at $target; backing it up to $backup"
      else
        warn "$target exists; backing it up to $backup before installing runtime launcher"
      fi
      mv "$target" "$backup"
    fi
  fi

  PRAXIS_LAUNCHER_TARGET="$target" \
  PRAXIS_LAUNCHER_SOURCE="$workflow_root/runtime/launcher_authority.py" \
    "$venv_dir/bin/python" - <<'PY'
import os
from pathlib import Path

target = Path(os.environ["PRAXIS_LAUNCHER_TARGET"])
source = Path(os.environ["PRAXIS_LAUNCHER_SOURCE"])
body = source.read_text(encoding="utf-8")
script = (
    "#!/usr/bin/env python3\n"
    "# Praxis runtime launcher. Managed by ./scripts/bootstrap.\n"
    "# Self-contained: resolves the checkout through launcher authority before importing repo code.\n"
    + body
)
target.write_text(script, encoding="utf-8")
target.chmod(0o755)
PY
}

# --- Step 1: prereqs ---------------------------------------------------------
step "Checking prerequisites"

if ! command -v python3.14 >/dev/null 2>&1; then
  die "python3.14 not on PATH. Install with: brew install python@3.14 (macOS) or your distro's equivalent."
fi
python_bin="$(command -v python3.14)"
ok "python3.14 at $python_bin"

require_gate platform.psql >/dev/null || exit 1
ok "psql at $(command -v psql)"

database_authority="$(
  resolve_database_authority
)" || die "could not resolve WORKFLOW_DATABASE_URL from repo authority"
database_url="$(printf '%s\n' "$database_authority" | sed -n '1p')"
database_authority_source="$(printf '%s\n' "$database_authority" | sed -n '2p')"
ok "database authority: $database_authority_source"

ensure_repo_env_file "$database_url"

database_meta="$(parse_database_authority)"
database_name="$(printf '%s\n' "$database_meta" | sed -n '1p')"
maintenance_url="$(printf '%s\n' "$database_meta" | sed -n '2p')"

if ! pg_isready -d "$maintenance_url" >/dev/null 2>&1; then
  die "Postgres maintenance database is not reachable for $(redact_url_for_log "$maintenance_url"). Start Postgres, then rerun ./scripts/bootstrap."
fi
ok "postgres maintenance database reachable"

step "Preparing workflow database"
WORKFLOW_DATABASE_URL="$database_url" \
  apply_gate platform.workflow_database --yes >/dev/null || exit 1
ok "database ready: $database_name"

WORKFLOW_DATABASE_URL="$database_url" \
  require_gate platform.pgvector >/dev/null || exit 1
WORKFLOW_DATABASE_URL="$database_url" \
  apply_gate platform.pgvector_installed --yes >/dev/null || exit 1
ok "pgvector extension enabled"

# --- Step 2: venv + dependencies --------------------------------------------
step "Setting up .venv"

venv_dir="$repo_root/.venv"
if [ ! -d "$venv_dir" ]; then
  "$python_bin" -m venv "$venv_dir"
  ok "created $venv_dir"
else
  ok ".venv already present"
fi

# shellcheck disable=SC1091
source "$venv_dir/bin/activate"

requirements="$workflow_root/requirements.runtime.txt"
if [ ! -f "$requirements" ]; then
  die "missing $requirements - is this the Praxis repo root?"
fi

pip install --quiet --upgrade pip
pip install --quiet -r "$requirements"
ok "dependencies installed from requirements.runtime.txt"

# --- Step 3: praxis CLI on PATH ---------------------------------------------
step "Installing praxis runtime launcher"

local_bin="${PRAXIS_LOCAL_BIN_DIR:-${XDG_BIN_HOME:-$HOME/.local/bin}}"
if [ -z "$local_bin" ]; then
  die "could not determine launcher install path: set PRAXIS_LOCAL_BIN_DIR, XDG_BIN_HOME, or HOME"
fi
if [ -z "${PRAXIS_LOCAL_BIN_DIR:-}" ] && [ -z "${XDG_BIN_HOME:-}" ]; then
  warn "PRAXIS_LOCAL_BIN_DIR / XDG_BIN_HOME not set; defaulting launcher install path to $local_bin"
fi
mkdir -p "$local_bin"
launcher_target="$local_bin/praxis"
launcher_config="$(launcher_config_path)"
checkout_command="$repo_root/scripts/praxis"

if [ ! -x "$checkout_command" ]; then
  die "scripts/praxis is not executable - run chmod +x scripts/praxis"
fi

write_launcher_seed_config "$launcher_config"
ok "launcher seed config written at $launcher_config"

install_runtime_launcher "$launcher_target"
ok "installed praxis runtime launcher at $launcher_target"

case ":$PATH:" in
  *":$local_bin:"*) ok "$local_bin is on PATH" ;;
  *) warn "$local_bin is NOT on PATH. Add it to your shell rc before invoking praxis" ;;
esac

# --- Step 4: db-bootstrap ---------------------------------------------------
step "Running db-bootstrap (schema + fresh-install authority seed)"
without_contract_env "$script_dir/native-bootstrap.sh" >/dev/null
ok "db-bootstrap completed"

# --- Step 5: native smoke ---------------------------------------------------
step "Running native self-hosted smoke"
if without_contract_env "$script_dir/native-smoke.sh" >/dev/null; then
  ok "native smoke passed"
else
  die "native smoke failed - run ./scripts/native-smoke.sh for full output"
fi

# --- Step 6: REST API -------------------------------------------------------
step "Starting REST API"
api_host="${PRAXIS_API_HOST:-127.0.0.1}"
api_port="${PRAXIS_API_PORT:-8420}"
api_probe_host="$api_host"
if [ "$api_probe_host" = "0.0.0.0" ]; then
  api_probe_host="127.0.0.1"
fi
api_health_url="http://$api_probe_host:$api_port/api/health"
api_state_dir="$repo_root/artifacts/bootstrap"
api_pid_file="$api_state_dir/api.pid"
api_log_file="$api_state_dir/api.log"
mkdir -p "$api_state_dir"

if probe_api "$api_health_url"; then
  ok "REST API already healthy at $api_health_url"
else
  without_contract_env \
    PYTHONPATH="$workflow_root${PYTHONPATH:+:$PYTHONPATH}" \
    PRAXIS_API_HOST="$api_host" \
    PRAXIS_API_PORT="$api_port" \
    "$venv_dir/bin/python" -m surfaces.api.server \
      --host "$api_host" \
      --port "$api_port" \
      > "$api_log_file" 2>&1 &
  api_pid="$!"
  printf '%s\n' "$api_pid" > "$api_pid_file"

  for _ in $(seq 1 30); do
    if probe_api "$api_health_url"; then
      ok "REST API healthy at $api_health_url (pid $api_pid)"
      break
    fi
    if ! kill -0 "$api_pid" >/dev/null 2>&1; then
      die "REST API exited during startup. See $api_log_file"
    fi
    sleep 1
  done

  if ! probe_api "$api_health_url"; then
    die "REST API did not become healthy at $api_health_url. See $api_log_file"
  fi
fi

# --- Step 7: deterministic worker smoke ------------------------------------
step "Running deterministic worker smoke"
smoke_spec="$repo_root/examples/bootstrap_smoke.queue.json"
if [ ! -f "$smoke_spec" ]; then
  die "missing $smoke_spec"
fi

without_contract_env "$script_dir/praxis" workflow validate "$smoke_spec" >/dev/null
ok "bootstrap smoke spec validated"

smoke_result_file="$api_state_dir/bootstrap_smoke_result.json"
rm -f "$smoke_result_file"
if without_contract_env "$script_dir/praxis" workflow run "$smoke_spec" \
    --fresh \
    --result-file "$smoke_result_file" \
    --foreground-submit >/dev/null; then
  ok "bootstrap smoke submitted"
else
  die "bootstrap smoke submit failed"
fi

smoke_run_id="$(
  "$python_bin" - "$smoke_result_file" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
payload = json.loads(path.read_text(encoding="utf-8"))
run_id = str(payload.get("run_id") or "").strip()
if not run_id:
    raise SystemExit(1)
print(run_id)
PY
)" || die "bootstrap smoke result file did not contain run_id"

smoke_timeout="${PRAXIS_BOOTSTRAP_SMOKE_TIMEOUT:-120}"
if without_contract_env "$script_dir/praxis" workflow stream "$smoke_run_id" \
    --timeout "$smoke_timeout" \
    --poll-interval 2 >/dev/null; then
  ok "bootstrap smoke passed"
else
  die "bootstrap smoke failed or timed out for $smoke_run_id"
fi

# --- Done -------------------------------------------------------------------
cat <<DONE

==> Bootstrap complete.

API:     http://$api_probe_host:$api_port/api/health
Moon:    (cd "Code&DBs/Workflow/surfaces/app" && npm install && npm run dev)
         Vite prints a URL — open it; Moon auto-connects to the API.

Next:
  praxis workflow query "status"                          # standing orders + status
  praxis workflow run examples/bootstrap_smoke.queue.json # deterministic smoke (no LLM)
  praxis workflow run examples/hello_world.queue.json     # LLM demo (needs provider key)

Host CLI dispatcher (Claude Code / Codex / Gemini):
  scripts/praxis-up agent-broker
  bin/praxis-agent --list

See README.md "First 5 minutes with Praxis" for the full demo walkthrough.

DONE
