#!/usr/bin/env bash
# Praxis fresh-clone bootstrap.
#
# Takes a fresh clone from zero to a verified install in one command:
#   1. Verify python3.14 + postgres are reachable.
#   2. Create .venv at repo root and install requirements.runtime.txt.
#   3. Symlink scripts/praxis into ~/.local/bin so `praxis` is on PATH.
#   4. Run db-bootstrap (via scripts/native-bootstrap.sh) -> full migration set.
#   5. Run the native self-hosted smoke (via scripts/native-smoke.sh).
#
# Idempotent: re-running on a healthy install is a no-op.
# Roadmap: roadmap_item.fresh.instance.onboarding.readiness.bootstrap.one.command.fresh.clone

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

step() { printf '\n\033[1;36m==> %s\033[0m\n' "$*"; }
ok()   { printf '  \033[1;32m[ok]\033[0m %s\n' "$*"; }
warn() { printf '  \033[1;33m[warn]\033[0m %s\n' "$*"; }
die()  { printf '  \033[1;31m[fail]\033[0m %s\n' "$*" >&2; exit 1; }

# --- Step 1: prereqs ---------------------------------------------------------
step "Checking prerequisites"

if ! command -v python3.14 >/dev/null 2>&1; then
  die "python3.14 not on PATH. Install with: brew install python@3.14 (macOS) or your distro's equivalent."
fi
python_bin="$(command -v python3.14)"
ok "python3.14 at $python_bin"

if ! command -v psql >/dev/null 2>&1; then
  die "psql not on PATH. Install Postgres 16+ with pgvector."
fi
ok "psql at $(command -v psql)"

if ! pg_isready -h localhost -p 5432 >/dev/null 2>&1; then
  die "Postgres not reachable at localhost:5432. Start it (e.g. brew services start postgresql@16)."
fi
ok "postgres reachable on localhost:5432"

# pgvector check — the workflow_database resolver will fail loudly later if it's missing,
# but give the user an earlier, friendlier signal.
if ! psql -h localhost -p 5432 -d postgres -tAc \
      "SELECT 1 FROM pg_available_extensions WHERE name='vector';" 2>/dev/null | grep -q 1; then
  warn "pgvector extension not visible via pg_available_extensions; db-bootstrap will fail if it's truly absent."
  warn "macOS install: https://github.com/pgvector/pgvector#installation-notes"
else
  ok "pgvector extension available"
fi

# --- Step 2: venv + dependencies --------------------------------------------
step "Setting up .venv"

venv_dir="$repo_root/.venv"
if [ ! -d "$venv_dir" ]; then
  "$python_bin" -m venv "$venv_dir"
  ok "created $venv_dir"
else
  ok ".venv already present"
fi

# shellcheck disable=SC1091
source "$venv_dir/bin/activate"

requirements="$repo_root/Code&DBs/Workflow/requirements.runtime.txt"
if [ ! -f "$requirements" ]; then
  die "missing $requirements — is this the Praxis repo root?"
fi

pip install --quiet --upgrade pip
pip install --quiet -r "$requirements"
ok "dependencies installed from requirements.runtime.txt"

# --- Step 3: praxis CLI on PATH ---------------------------------------------
step "Installing praxis CLI shim"

local_bin="${HOME}/.local/bin"
mkdir -p "$local_bin"
shim_target="$local_bin/praxis"
shim_source="$repo_root/scripts/praxis"

if [ ! -x "$shim_source" ]; then
  die "scripts/praxis is not executable — run chmod +x scripts/praxis"
fi

if [ -L "$shim_target" ] && [ "$(readlink "$shim_target")" = "$shim_source" ]; then
  ok "praxis shim already points at $shim_source"
elif [ -e "$shim_target" ]; then
  warn "$shim_target exists but does not point at this repo; leaving it alone"
else
  ln -s "$shim_source" "$shim_target"
  ok "linked $shim_target -> $shim_source"
fi

case ":$PATH:" in
  *":$local_bin:"*) ok "$local_bin is on PATH" ;;
  *) warn "$local_bin is NOT on PATH. Add to your shell rc: export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
esac

# --- Step 4: db-bootstrap ---------------------------------------------------
step "Running db-bootstrap (migrations + bootstrap_only data)"
"$script_dir/native-bootstrap.sh" >/dev/null
ok "db-bootstrap completed"

# --- Step 5: smoke ----------------------------------------------------------
step "Running native self-hosted smoke"
if "$script_dir/native-smoke.sh" >/dev/null; then
  ok "smoke passed"
else
  die "smoke failed — run ./scripts/native-smoke.sh for full output"
fi

# --- Done -------------------------------------------------------------------
cat <<'DONE'

==> Bootstrap complete.

Next:
  praxis workflow query "status"                    # orient
  praxis workflow run examples/hello_world.queue.json
  (cd Code\&DBs/Workflow/surfaces/app && npm install && npm run dev)   # Moon UI

DONE
