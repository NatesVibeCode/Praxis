#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck source=_workflow_env.sh
source "$REPO_ROOT/scripts/_workflow_env.sh"
# Use the canonical workflow tree from the checked-in workspace layout config.
WORKFLOW_DIR="$(workflow_repo_workflow_root)"
PYTHON_BIN="${PYTHON_BIN:-$(workflow_python_bin)}"
COMMAND_NAME="${PRAXIS_COMMAND_NAME:-praxis}"
SERVICE_MANAGER_PATH="${PRAXIS_SERVICE_MANAGER_PATH:-scripts/praxis}"
COMPATIBILITY_ALIAS_PATH="${PRAXIS_COMPATIBILITY_ALIAS_PATH:-scripts/praxis-ctl}"
PREFERRED_COMMAND_NAME="${PRAXIS_PREFERRED_COMMAND_NAME:-praxis}"
LAUNCHER_STATE_DIR="${PRAXIS_LAUNCHER_STATE_DIR:-$REPO_ROOT/.cache/praxis-launcher}"
LAUNCHER_STATE_FILE="$LAUNCHER_STATE_DIR/state.json"

ensure_workflow_database_env() {
    if [ -n "${WORKFLOW_DATABASE_URL:-}" ] && [ -n "${PRAXIS_WORKSPACE_BASE_PATH:-}" ]; then
        return 0
    fi
    # shellcheck disable=SC1090
    source "$SCRIPT_DIR/_workflow_env.sh"
    workflow_load_repo_env
}

record_praxis_shell_failure() {
    if [ "$#" -lt 2 ]; then
        echo "usage: record_praxis_shell_failure <exit_code> <command_label_prefix> [command...]" >&2
        return 2
    fi

    local exit_code="$1"
    local command_label_prefix="$2"
    shift 2

    PYTHONPATH="$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}" \
        "$PYTHON_BIN" - "$exit_code" "$command_label_prefix" "$@" <<'PY'
import os
import sys

from surfaces.cli.friction import record_shell_command_failure

exit_code = int(sys.argv[1])
command_label_prefix = sys.argv[2]
args = sys.argv[3:]
output_text = sys.stdin.read()
record_shell_command_failure(
    args=args,
    exit_code=exit_code,
    output_text=output_text,
    env=os.environ,
    command_label_prefix=command_label_prefix,
)
PY
}

ensure_workflow_database_env_with_recording() {
    if [ "$#" -lt 1 ]; then
        echo "usage: ensure_workflow_database_env_with_recording <command_label_prefix> [command...]" >&2
        return 2
    fi

    local command_label_prefix="$1"
    shift

    local output_file
    output_file="$(mktemp "${TMPDIR:-/tmp}/praxis-env-failure.XXXXXX")" || return 1

    if ensure_workflow_database_env >"$output_file" 2>&1; then
        rm -f "$output_file"
        return 0
    fi

    local exit_code=$?
    local output_text
    output_text="$(cat "$output_file")"
    rm -f "$output_file"
    printf '%s\n' "$output_text" >&2
    printf '%s' "$output_text" | record_praxis_shell_failure "$exit_code" "$command_label_prefix" "$@"
    return "$exit_code"
}

run_shell_command_with_recording() {
    if [ "$#" -lt 3 ]; then
        echo "usage: run_shell_command_with_recording <command_label_prefix> <command_name> <command> [args...]" >&2
        return 2
    fi

    local command_label_prefix="$1"
    local command_name="$2"
    shift 2

    local output_file
    output_file="$(mktemp "${TMPDIR:-/tmp}/praxis-shell-failure.XXXXXX")" || return 1

    local exit_code=0
    if "$@" > >(tee "$output_file") 2> >(tee -a "$output_file" >&2); then
        :
    else
        exit_code=$?
        local output_text
        output_text="$(cat "$output_file")"
        printf '%s' "$output_text" | record_praxis_shell_failure "$exit_code" "$command_label_prefix" "$command_name" "${@:2}"
    fi

    rm -f "$output_file"
    return "$exit_code"
}

workflow_subcommand_needs_database_env() {
    local subcommand="${1:-help}"
    shift || true
    case "$subcommand" in
        help|--help|-h|commands|routes)
            return 1
            ;;
        dry-run)
            return 1
            ;;
        run)
            for arg in "$@"; do
                case "$arg" in
                    --dry-run|--help|-h)
                        return 1
                        ;;
                esac
            done
            ;;
    esac
    return 0
}

docker_only_usage() {
    cat <<EOF
Usage: ${COMMAND_NAME} <command> [service]

Authoritative namespaces:
  workflow ...            Canonical execution, query, and operator authority
  db ...                  Schema authority plus SQL scaffolds
  registry ...            Manifest registry authority
  object-type ...         Object-type authority and scaffolds
  objects ...             Object record authority
  catalog ...             Surface catalog authority
  data ...                Data shaping plans plus workflow data actions
  dataset ...             Dataset refinery (curated training data for specialist SLMs)
  page ...                App/page scaffolds
  hierarchy ...           Hierarchy scaffolds
  reload                  Runtime reload authority
  reconcile               Data reconcile authority

Docker-only commands:
  launch                  Start cockpit Docker services, probe launcher readiness, and optionally open /app
  doctor --json           Emit semantic launcher readiness as JSON
  repair-sync [run_id]    Re-run workflow sync for the latest degraded run or a specific run
  status [--json]         Show Docker service state and active workflows
  start [service...]      Start Docker services (default: cockpit)
  stop [service...]       Stop Docker services (default: cockpit)
  restart [service...]    Restart Docker services AND kill any host MCP daemons (default: cockpit)
  logs [service...]       Show Docker logs (default: cockpit, tail=200)

Other commands:
  setup ...               Runtime-target setup client for API/MCP authority
  workflow ...            Delegate to workflow CLI
  mcp serve               Run the MCP server through launcher/workspace authority
  agent-run               Run the Praxis supervisor agent entrypoint

Services:
  semantic | semantic-backend
  api | api-server | server | workflow-api
  worker | workflow-worker | queue-worker
  scheduler

Notes:
  - Native launchd install/setup control has been removed.
  - workflow-worker is an explicit execution-node profile; default launch/start is cockpit-only.
  - ${PREFERRED_COMMAND_NAME} is the preferred launcher front door.
  - ${COMPATIBILITY_ALIAS_PATH} remains a compatibility alias.
EOF
}

require_docker() {
    if ! command -v docker >/dev/null 2>&1; then
        echo "Docker is required for Praxis docker-only control." >&2
        exit 1
    fi
}

normalize_docker_service() {
    case "${1:-}" in
        postgres|pg)
            echo "Postgres is external to this compose stack; set WORKFLOW_DATABASE_URL instead of starting a postgres service." >&2
            exit 1
            ;;
        semantic|semantic-backend|embedding|embedding-backend)
            echo "semantic-backend"
            ;;
        api|api-server|server|praxis-server|workflow-api)
            echo "api-server"
            ;;
        worker|workflow-worker|queue-worker)
            echo "workflow-worker"
            ;;
        scheduler)
            echo "scheduler"
            ;;
        all|"")
            echo ""
            ;;
        *)
            echo "Unknown Docker service: $1" >&2
            exit 1
            ;;
    esac
}

docker_services_from_args() {
    local normalized
    if [ "$#" -eq 0 ]; then
        printf '%s\n' semantic-backend api-server scheduler
        return
    fi
    for arg in "$@"; do
        normalized="$(normalize_docker_service "$arg")"
        if [ -n "$normalized" ]; then
            printf '%s\n' "$normalized"
        fi
    done | awk '!seen[$0]++'
}

docker_only_start() {
    require_docker
    mapfile -t services < <(docker_services_from_args "$@")
    (cd "$REPO_ROOT" && docker compose up -d "${services[@]}")
}

docker_only_stop() {
    require_docker
    mapfile -t services < <(docker_services_from_args "$@")
    (cd "$REPO_ROOT" && docker compose stop "${services[@]}")
}

kill_host_mcp_daemons() {
    # Force-rotate any host-side `python3 -m surfaces.mcp` daemons so
    # Claude / other MCP clients respawn against the freshly-restarted
    # backend. Without this, restart only bounces docker — host daemons
    # keep running stale code and reattaching to the same Python process,
    # so file edits silently fail to take effect on MCP-routed calls.
    #
    # Whatever spawned each daemon (Claude Code, Codex, etc.) is
    # responsible for respawning on next MCP call; this command just
    # kills the stuck process.
    local pids=()
    if command -v pgrep >/dev/null 2>&1; then
        mapfile -t pids < <(pgrep -f 'python3 -m surfaces.mcp' 2>/dev/null || true)
    fi
    if [ "${#pids[@]}" -eq 0 ]; then
        echo "  no host MCP daemons running"
        return 0
    fi
    echo "  killing host MCP daemons: ${pids[*]}"
    # SIGKILL: SIGTERM is often caught by the disclaimer wrapper and
    # the python child survives. -9 is the only signal that reliably
    # rotates the actual python process.
    kill -9 "${pids[@]}" 2>/dev/null || true
}

docker_only_restart() {
    require_docker
    mapfile -t services < <(docker_services_from_args "$@")
    (cd "$REPO_ROOT" && docker compose restart "${services[@]}")
    echo "Rotating host MCP daemons:"
    kill_host_mcp_daemons
}

docker_only_logs() {
    require_docker
    local -a services=()
    local -a options=()
    local arg
    local saw_tail=0
    local saw_follow=0
    while [ "$#" -gt 0 ]; do
        arg="$1"
        if [[ "$arg" == -* ]]; then
            options+=("$arg")
            case "$arg" in
                --tail|-n)
                    saw_tail=1
                    shift
                    if [ "$#" -gt 0 ]; then
                        options+=("$1")
                    fi
                    shift
                    continue
                    ;;
                --tail=*)
                    saw_tail=1
                    ;;
                -f|--follow)
                    saw_follow=1
                    ;;
            esac
            shift
            continue
        fi
        services+=("$(normalize_docker_service "$arg")")
        shift
    done
    if [ "${#services[@]}" -eq 0 ]; then
        mapfile -t services < <(docker_services_from_args)
    fi
    if [ "$saw_tail" -eq 0 ] && [ "$saw_follow" -eq 0 ]; then
        options=(--tail=200 "${options[@]}")
    fi
    (cd "$REPO_ROOT" && docker compose logs "${options[@]}" "${services[@]}")
}

docker_compose_ps_json() {
    require_docker

    if ! (cd "$REPO_ROOT" && docker compose ps --format json 2>/dev/null); then
        echo "Praxis Docker authority is unavailable. Run from the repo with Docker Compose available." >&2
        return 1
    fi
}

run_local_alpha() {
    mkdir -p "$LAUNCHER_STATE_DIR"
    local subcommand="${1:-}"
    shift || true

    case "$subcommand" in
        doctor)
            local services_ready=""
            local state_file=""
            while [ "$#" -gt 0 ]; do
                case "$1" in
                    --services-ready)
                        services_ready="${2:-}"
                        shift 2
                        ;;
                    --state-file)
                        state_file="${2:-}"
                        shift 2
                        ;;
                    *)
                        echo "Unsupported local-alpha doctor argument: $1" >&2
                        return 1
                        ;;
                esac
            done
            ensure_workflow_database_env
            PYTHONPATH="$SCRIPT_DIR:$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}" \
            WORKFLOW_DATABASE_URL="${WORKFLOW_DATABASE_URL}" \
            PRAXIS_ALPHA_SERVICES_READY="$services_ready" \
            PRAXIS_ALPHA_STATE_FILE="$state_file" \
                "$PYTHON_BIN" - <<'PY'
import os

from praxis_ctl_local_alpha import cmd_doctor

raise SystemExit(
    cmd_doctor(
        services_ready=os.environ["PRAXIS_ALPHA_SERVICES_READY"],
        state_file=os.environ["PRAXIS_ALPHA_STATE_FILE"],
    )
)
PY
            ;;
        repair-sync)
            local run_id=""
            while [ "$#" -gt 0 ]; do
                case "$1" in
                    --run-id)
                        run_id="${2:-}"
                        shift 2
                        ;;
                    *)
                        echo "Unsupported local-alpha repair-sync argument: $1" >&2
                        return 1
                        ;;
                esac
            done
            ensure_workflow_database_env
            PYTHONPATH="$SCRIPT_DIR:$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}" \
            WORKFLOW_DATABASE_URL="${WORKFLOW_DATABASE_URL}" \
            PRAXIS_ALPHA_RUN_ID="$run_id" \
                "$PYTHON_BIN" - <<'PY'
import os

from praxis_ctl_local_alpha import cmd_repair_sync

run_id = os.environ.get("PRAXIS_ALPHA_RUN_ID") or None
raise SystemExit(cmd_repair_sync(run_id=run_id))
PY
            ;;
        *)
            echo "Unsupported local-alpha command: ${subcommand}" >&2
            return 1
            ;;
    esac
}

docker_services_ready() {
    local compose_json="${1:-}"
    PRAXIS_COMPOSE_JSON="$compose_json" "$PYTHON_BIN" - <<'PY'
import json
import os
import sys

raw = os.environ.get("PRAXIS_COMPOSE_JSON", "").strip()
services = []
if raw:
    try:
        services = json.loads(raw)
    except json.JSONDecodeError:
        services = [json.loads(line) for line in raw.splitlines() if line.strip()]
if isinstance(services, dict):
    services = [services]

required = {"api-server", "scheduler", "semantic-backend"}
states = {}
for service in services:
    name = str(service.get("Service") or service.get("Name") or "").strip()
    state = str(service.get("State") or service.get("Status") or "").strip().lower()
    if name:
        states[name] = state

ready = all(states.get(name) in {"running", "healthy"} for name in required)
raise SystemExit(0 if ready else 1)
PY
}

launcher_doctor_payload() {
    local compose_json="${1:-}"
    local services_ready="false"
    if docker_services_ready "$compose_json"; then
        services_ready="true"
    fi
    local base_payload
    base_payload="$(run_local_alpha doctor --services-ready "$services_ready" --state-file "$LAUNCHER_STATE_FILE")"
    PRAXIS_DOCTOR_BASE_PAYLOAD="$base_payload" \
    PYTHONPATH="$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}" \
        "$PYTHON_BIN" - <<'PY'
import json
import os

from runtime.setup_wizard import enrich_doctor_payload

payload = json.loads(os.environ.get("PRAXIS_DOCTOR_BASE_PAYLOAD") or "{}")
print(json.dumps(enrich_doctor_payload(payload), sort_keys=True))
PY
}

doctor_field_is_true() {
    local payload="${1:-}"
    local field="${2:-}"
    DOCTOR_JSON="$payload" DOCTOR_FIELD="$field" "$PYTHON_BIN" - <<'PY'
import json
import os
import sys

payload = json.loads(os.environ.get("DOCTOR_JSON") or "{}")
field = os.environ.get("DOCTOR_FIELD", "")
raise SystemExit(0 if bool(payload.get(field)) else 1)
PY
}

doctor_ready() {
    local payload="${1:-}"
    doctor_field_is_true "$payload" "services_ready" \
        && doctor_field_is_true "$payload" "database_reachable" \
        && doctor_field_is_true "$payload" "workflow_operational" \
        && doctor_field_is_true "$payload" "api_server_ready" \
        && doctor_field_is_true "$payload" "workflow_api_ready" \
        && doctor_field_is_true "$payload" "mcp_bridge_ready" \
        && doctor_field_is_true "$payload" "ui_ready"
}

launcher_status_json() {
    local compose_json="${1:-}"
    local doctor_json="${2:-}"
    PRAXIS_COMPOSE_JSON="$compose_json" \
    DOCTOR_JSON="$doctor_json" \
    COMMAND_NAME="$COMMAND_NAME" \
    SERVICE_MANAGER_PATH="$SERVICE_MANAGER_PATH" \
    COMPATIBILITY_ALIAS_PATH="$COMPATIBILITY_ALIAS_PATH" \
    "$PYTHON_BIN" - <<'PY'
import json
import os

compose_raw = os.environ.get("PRAXIS_COMPOSE_JSON", "").strip()
doctor = json.loads(os.environ.get("DOCTOR_JSON") or "{}")
services = []
if compose_raw:
    try:
        services = json.loads(compose_raw)
    except json.JSONDecodeError:
        services = [json.loads(line) for line in compose_raw.splitlines() if line.strip()]
if isinstance(services, dict):
    services = [services]

normalized = []
for service in services:
    name = service.get("Service") or service.get("Name")
    state = service.get("State") or service.get("Status")
    health = service.get("Health")
    ports = service.get("Publishers") or []
    normalized.append(
        {
            "label": name,
            "name": name,
            "loaded": bool(name),
            "running": str(state or "").strip().lower() in {"running", "healthy"},
            "pid": None,
            "exit_code": None,
            "port": next((p.get("PublishedPort") for p in ports if p.get("PublishedPort")), None),
            "log_file": None,
            "state": state or "unknown",
            "health": health or None,
        }
    )

payload = {
    "ok": True,
    "brand": "Praxis Engine",
    "service_manager": os.environ.get("SERVICE_MANAGER_PATH", "scripts/praxis"),
    "compatibility_alias": os.environ.get("COMPATIBILITY_ALIAS_PATH", "scripts/praxis-ctl"),
    "preferred_command": os.environ.get("COMMAND_NAME", "praxis"),
    "services": normalized,
    "doctor": doctor,
    "dependency_truth": doctor.get("dependency_truth"),
    "database_reachable": doctor.get("database_reachable"),
    "schema_bootstrapped": doctor.get("schema_bootstrapped"),
    "workflow_operational": doctor.get("workflow_operational"),
    "missing_schema_objects": doctor.get("missing_schema_objects"),
    "api_server_ready": doctor.get("api_server_ready"),
    "workflow_api_ready": doctor.get("workflow_api_ready"),
    "mcp_bridge_ready": doctor.get("mcp_bridge_ready"),
    "ui_ready": doctor.get("ui_ready"),
    "launch_url": doctor.get("launch_url"),
    "dashboard_url": doctor.get("dashboard_url"),
    "api_docs_url": doctor.get("api_docs_url"),
    "workflow_api_base_url": doctor.get("workflow_api_base_url"),
    "workflow_api_authority_source": doctor.get("workflow_api_authority_source"),
}
print(json.dumps(payload, indent=2, sort_keys=True))
PY
}

docker_only_status() {
    local as_json="false"
    if [ "${1:-}" = "--json" ]; then
        as_json="true"
    elif [ "$#" -gt 0 ]; then
        echo "Usage: ${COMMAND_NAME} status [--json]" >&2
        return 1
    fi

    local compose_json
    compose_json="$(docker_compose_ps_json)" || return 1
    local doctor_json
    doctor_json="$(launcher_doctor_payload "$compose_json")"

    if [ "$as_json" = "true" ]; then
        launcher_status_json "$compose_json" "$doctor_json"
        return 0
    fi

    echo "Praxis mode: docker-only"
    PRAXIS_COMPOSE_JSON="$compose_json" "$PYTHON_BIN" - <<'PY'
import json
import os
import sys

raw = os.environ.get("PRAXIS_COMPOSE_JSON", "").strip()
if not raw:
    services = []
else:
    try:
        services = json.loads(raw)
    except json.JSONDecodeError:
        services = [json.loads(line) for line in raw.splitlines() if line.strip()]
    if isinstance(services, dict):
        services = [services]

if not services:
    print("Services: none")
else:
    print("Services:")
    for service in services:
        name = service.get("Service") or service.get("Name") or "unknown"
        state = service.get("State") or service.get("Status") or "unknown"
        health = service.get("Health") or ""
        ports = service.get("Publishers") or []
        published = []
        for port in ports:
            url = port.get("URL") or ""
            target = port.get("TargetPort")
            published_port = port.get("PublishedPort")
            protocol = port.get("Protocol") or "tcp"
            if published_port and target:
                published.append(f"{url}:{published_port}->{target}/{protocol}".replace("tcp://", ""))
        suffix = f" [{health}]" if health else ""
        port_suffix = f" ({', '.join(published)})" if published else ""
        print(f"  - {name}: {state}{suffix}{port_suffix}")
PY

    local snapshot_output
    if snapshot_output="$(cd "$REPO_ROOT" && ./scripts/praxis workflow tools call praxis_status_snapshot --input-json '{"since_hours":24}' 2>/dev/null)"; then
        if [ -n "$snapshot_output" ]; then
            echo ""
            PRAXIS_STATUS_SNAPSHOT="$snapshot_output" "$PYTHON_BIN" - <<'PY'
import json
import os


def pct(value):
    try:
        return f"{float(value) * 100:.1f}%"
    except (TypeError, ValueError):
        return "n/a"


def seconds(value):
    try:
        total = float(value)
    except (TypeError, ValueError):
        return "n/a"
    if total < 60:
        return f"{total:.0f}s"
    minutes = total / 60
    if minutes < 60:
        return f"{minutes:.1f}m"
    return f"{minutes / 60:.1f}h"


snapshot = json.loads(os.environ.get("PRAXIS_STATUS_SNAPSHOT") or "{}")
print("Workflow snapshot:")
print(
    "  - 24h: "
    f"{snapshot.get('total_workflows', 0)} runs, "
    f"pass rate {pct(snapshot.get('pass_rate'))}, "
    f"adjusted {pct(snapshot.get('adjusted_pass_rate'))}, "
    f"observability {snapshot.get('observability_state', 'unknown')}"
)
print(
    "  - queue: "
    f"depth={snapshot.get('queue_depth', 0)} "
    f"pending={snapshot.get('queue_depth_pending', 0)} "
    f"ready={snapshot.get('queue_depth_ready', 0)} "
    f"running={snapshot.get('queue_depth_running', 0)} "
    f"status={snapshot.get('queue_depth_status', 'unknown')}"
)
runs = snapshot.get("in_flight_workflows")
if not isinstance(runs, list):
    runs = []
print("Active workflows:")
if not runs:
    print("  - none")
else:
    for run in runs:
        if not isinstance(run, dict):
            continue
        run_id = run.get("run_id", "unknown")
        name = run.get("workflow_name") or run_id
        completed = run.get("completed_jobs", 0)
        total = run.get("total_jobs", 0)
        elapsed = seconds(run.get("elapsed_seconds"))
        print(f"  - {run_id}: {name} ({completed}/{total}, {elapsed})")
PY
        fi
    else
        echo ""
        echo "Workflow snapshot: unavailable"
    fi

    echo ""
    DOCTOR_JSON="$doctor_json" "$PYTHON_BIN" - <<'PY'
import json
import os

doctor = json.loads(os.environ.get("DOCTOR_JSON") or "{}")
ready = bool(doctor.get("api_server_ready")) and bool(doctor.get("ui_ready"))
heading = "Links:" if ready else "Links (API/UI readiness degraded):"
app_url = doctor.get("dashboard_url") or doctor.get("launch_url")
docs_url = doctor.get("api_docs_url")
workflow_api_url = doctor.get("workflow_api_base_url")
print(heading)
print(f"  - App:  {app_url or '(unavailable)'}")
print(f"  - Docs: {docs_url or '(unavailable)'}")
if workflow_api_url:
    print(f"  - Workflow API: {workflow_api_url}")
if not ready:
    print(f"  - Diagnose: {os.environ.get('COMMAND_NAME', 'praxis')} doctor --json")
PY
}

open_in_browser() {
    local target_url="${1:-}"
    if [ -z "$target_url" ]; then
        return 1
    fi
    if command -v open >/dev/null 2>&1; then
        open "$target_url" >/dev/null 2>&1
        return 0
    fi
    return 1
}

docker_only_launch() {
    local as_json="false"
    local no_open="false"
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --json) as_json="true" ;;
            --no-open) no_open="true" ;;
            *)
                echo "Usage: ${COMMAND_NAME} launch [--json] [--no-open]" >&2
                return 1
                ;;
        esac
        shift
    done

    docker_only_start

    local compose_json
    compose_json="$(docker_compose_ps_json)" || return 1
    local doctor_json
    doctor_json="$(launcher_doctor_payload "$compose_json")"
    local launch_url
    launch_url="$(DOCTOR_JSON="$doctor_json" "$PYTHON_BIN" - <<'PY'
import json
import os

payload = json.loads(os.environ.get("DOCTOR_JSON") or "{}")
print(payload.get("launch_url") or "")
PY
)"

    local opened="false"
    if doctor_ready "$doctor_json" && [ "$no_open" != "true" ] && open_in_browser "$launch_url"; then
        opened="true"
    fi

    if [ "$as_json" = "true" ]; then
        DOCTOR_JSON="$doctor_json" OPENED="$opened" COMMAND_NAME="$COMMAND_NAME" "$PYTHON_BIN" - <<'PY'
import json
import os

doctor = json.loads(os.environ.get("DOCTOR_JSON") or "{}")
ok = all(
    bool(doctor.get(field))
    for field in (
        "services_ready",
        "database_reachable",
        "workflow_operational",
        "api_server_ready",
        "workflow_api_ready",
        "mcp_bridge_ready",
        "ui_ready",
    )
)
payload = {
    "ok": ok,
    "brand": "Praxis Engine",
    "command": f"{os.environ.get('COMMAND_NAME', 'praxis')} launch",
    "opened": os.environ.get("OPENED") == "true",
    "failure_reason": None if ok else "semantic_readiness_failed",
    "doctor": doctor,
    "launch_url": doctor.get("launch_url"),
    "dashboard_url": doctor.get("dashboard_url") or doctor.get("launch_url"),
    "api_docs_url": doctor.get("api_docs_url"),
}
print(json.dumps(payload, indent=2, sort_keys=True))
raise SystemExit(0 if ok else 1)
PY
        return $?
    fi

    if doctor_ready "$doctor_json"; then
        if [ -n "$launch_url" ]; then
            echo "Praxis launcher ready: $launch_url"
        else
            echo "Praxis launcher ready"
        fi
        return 0
    fi

    echo "Praxis launcher readiness checks failed. Run ${COMMAND_NAME} doctor --json for details." >&2
    return 1
}

docker_only_doctor() {
    if [ "${1:-}" != "--json" ] || [ "$#" -ne 1 ]; then
        echo "Usage: ${COMMAND_NAME} doctor --json" >&2
        return 1
    fi
    local compose_json
    compose_json="$(docker_compose_ps_json)" || return 1
    launcher_doctor_payload "$compose_json"
}

docker_only_repair_sync() {
    if [ -n "${1:-}" ]; then
        run_local_alpha repair-sync --run-id "$1"
        return
    fi
    run_local_alpha repair-sync
}

unsupported_native_command() {
    local command_name="${1:-}"
    local message
    message=$(
        cat <<EOF
${COMMAND_NAME} ${command_name} is no longer supported.
Native install/setup launchd control has been removed.
Use ${COMMAND_NAME} start|stop|restart|status|logs for Docker runtime control,
${COMMAND_NAME} launch|doctor for launcher readiness, and ${COMMAND_NAME} workflow ... for operator authority.
EOF
    )
    printf '%s\n' "$message" >&2
    printf '%s' "$message" | record_praxis_shell_failure 1 praxis "$command_name"
    return 1
}

if [ "${1:-}" = "agent-run" ]; then
    export PYTHONPATH="$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}"
    exec python3 -m runtime.praxis_supervisor --repo-root "$REPO_ROOT" run
fi

if [ "${1:-}" = "workflow" ]; then
    shift
    if workflow_subcommand_needs_database_env "$@"; then
        ensure_workflow_database_env_with_recording workflow "$@" || exit "$?"
    fi
    export PYTHONPATH="$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}"
    case "${1:-help}" in
      run-managed)
        shift
        exec "$PYTHON_BIN" -m surfaces.cli.main workflow run "$@"
        ;;
      spawn-managed)
        shift
        exec "$PYTHON_BIN" -m surfaces.cli.main workflow spawn "$@"
        ;;
      dry-run)
        shift
        exec "$PYTHON_BIN" -m surfaces.cli.main workflow dry-run "$@"
        ;;
      *)
        exec "$PYTHON_BIN" -m surfaces.cli.main workflow "$@"
        ;;
    esac
fi

if [ "${1:-}" = "mcp" ]; then
    shift
    ensure_workflow_database_env_with_recording mcp "${1:-serve}" "${@:2}" || exit "$?"
    export PYTHONPATH="$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}"
    case "${1:-serve}" in
      serve|server|"")
        exec "$PYTHON_BIN" -m surfaces.mcp.server
        ;;
      *)
        echo "usage: ${COMMAND_NAME} mcp serve" >&2
        exit 2
        ;;
    esac
fi

case "${1:-}" in
    launcher|db|registry|object-type|objects|object|catalog|data|dataset|page|hierarchy|reload|reconcile)
        export PYTHONPATH="$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}"
        PYTHON_BIN="${PYTHON_BIN:-$(command -v python3.14 || command -v python3.13 || command -v python3)}"
        exec "$PYTHON_BIN" -m surfaces.cli.praxis "$@"
        ;;
esac

case "${1:-}" in
    help|--help|-h)
        docker_only_usage
        exit 0
        ;;
    launch)
        shift
        run_shell_command_with_recording praxis launch docker_only_launch "$@"
        exit $?
        ;;
    doctor)
        shift
        run_shell_command_with_recording praxis doctor docker_only_doctor "$@"
        exit $?
        ;;
    repair-sync)
        shift
        run_shell_command_with_recording praxis repair-sync docker_only_repair_sync "$@"
        exit $?
        ;;
    status)
        shift
        run_shell_command_with_recording praxis status docker_only_status "$@"
        exit $?
        ;;
    start)
        shift
        run_shell_command_with_recording praxis start docker_only_start "$@"
        exit $?
        ;;
    stop)
        shift
        run_shell_command_with_recording praxis stop docker_only_stop "$@"
        exit $?
        ;;
    restart)
        shift
        run_shell_command_with_recording praxis restart docker_only_restart "$@"
        exit $?
        ;;
    logs)
        shift
        run_shell_command_with_recording praxis logs docker_only_logs "$@"
        exit $?
        ;;
    setup)
        shift
        export PYTHONPATH="$WORKFLOW_DIR${PYTHONPATH:+:$PYTHONPATH}"
        exec "$PYTHON_BIN" -m runtime.setup_wizard "$@"
        ;;
    install|uninstall)
        unsupported_native_command "${1:-}"
        exit 1
        ;;
    "")
        usage_output="$(docker_only_usage)"
        printf '%s\n' "$usage_output"
        printf '%s' "$usage_output" | record_praxis_shell_failure 1 praxis
        exit 1
        ;;
esac

unknown_command_output="Unknown command: ${1:-} (try: ${COMMAND_NAME} help)"
printf '%s\n' "$unknown_command_output" >&2
printf '%s\n' "$unknown_command_output" | record_praxis_shell_failure 1 praxis "${1:-}"
exit 1
