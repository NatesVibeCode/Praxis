    <string>com.praxis.authority-memory-refresh</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/nate/Praxis/scripts/refresh_authority_memory.py</string>
