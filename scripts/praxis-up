#!/usr/bin/env bash
# praxis-up — single command to recreate Praxis containers with host-resolved
# integration/provider env and verify control-plane liveness.
#
# Why this exists:
#   Integration/API env (OPENROUTER_API_KEY, FIREWORKS_API_KEY, etc.) is
#   resolved on the host, then bridged into long-lived control containers at
#   recreate time. docker-compose resolves env vars at recreate time from the
#   calling shell, so the chain is:
#
#       eval "$(bin/praxis-compose-env)"   # keychain → shell exports
#       docker compose up -d --force-recreate <services>
#
#   Operators kept forgetting one half or the other, leaving containers with
#   stale env. This script bundles both into one invocation. Provider CLI auth
#   is no longer a worker-container health gate: provider-specific execution
#   uses thin sandbox images plus DB-backed credential/catalog authority.
#
# Standing-order references:
#   architecture-policy::auth::via-docker-creds-not-shell
#   architecture-policy::deployment::docker-restart-caches-env
#
# Usage:
#   scripts/praxis-up               # recreate agent-broker + api-server + worker + scheduler
#   scripts/praxis-up <service>...  # recreate only the named services
#   scripts/praxis-up --verify-only # skip recreate, just check worker liveness
#
# Exit codes:
#   0 — recreate succeeded AND liveness check passed
#   1 — recreate succeeded but liveness verification failed
#   2 — usage error
#   3 — recreate or compose-env failed

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE_ENV_BIN="${REPO_ROOT}/bin/praxis-compose-env"

DEFAULT_SERVICES=(agent-broker api-server workflow-worker scheduler)

service_selected() {
  local target="$1"
  local service
  for service in "${SERVICES[@]}"; do
    [[ "$service" == "$target" ]] && return 0
  done
  return 1
}

VERIFY_ONLY=0
SERVICES=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      cat <<'USAGE'
praxis-up — Keychain env hydrate + compose recreate (one command).

Usage:
  scripts/praxis-up
  scripts/praxis-up <service>...
  scripts/praxis-up --verify-only

Examples:
  scripts/praxis-up                           # default broker/API/worker/scheduler
  scripts/praxis-up workflow-worker           # just the worker
  scripts/praxis-up --verify-only             # skip recreate, check worker liveness

This is the right path after:
  - Docker Desktop / OrbStack restart
  - macOS reboot
  - Keychain-backed integration/provider env refresh
  - Worker container appearing healthy in `docker ps` but failing liveness
USAGE
      exit 0
      ;;
    --verify-only)
      VERIFY_ONLY=1
      shift
      ;;
    *)
      SERVICES+=("$1")
      shift
      ;;
  esac
done

if [[ ${#SERVICES[@]} -eq 0 ]]; then
  SERVICES=("${DEFAULT_SERVICES[@]}")
fi

cd "$REPO_ROOT"

if [[ $VERIFY_ONLY -eq 0 ]]; then
  if [[ ! -x "$COMPOSE_ENV_BIN" ]]; then
    echo "praxis-up: $COMPOSE_ENV_BIN missing or not executable" >&2
    exit 3
  fi

  # Pre-create the Claude credentials file path for control-plane services that
  # still expose direct interactive agent sessions. The workflow worker does
  # not mount provider CLI auth homes. Otherwise (host file missing) Docker
  # silently
  # creates the path as a *directory* on host, the container then mounts a
  # directory at /root/.claude/.credentials.json, and the claude CLI's file-
  # auth fallback fails open with "loggedIn: false". Operator fix path is
  # CLAUDE_CODE_OAUTH_TOKEN env (set above), but the directory-mount also
  # corrupts the host so subsequent `claude login` writes fail. Touching an
  # empty file here is idempotent: if a real credentials file already exists,
  # touch only updates mtime; if it's a directory, the touch fails and we
  # warn-and-clear so the next login can proceed cleanly.
  CLI_AUTH_HOME="${PRAXIS_CLI_AUTH_HOME:-${HOME:?HOME must be set}}"
  CRED_PATH="${CLI_AUTH_HOME}/.claude/.credentials.json"
  mkdir -p "${CLI_AUTH_HOME}/.claude"
  if [[ -d "$CRED_PATH" ]]; then
    echo "praxis-up: WARN — $CRED_PATH is a directory (docker-compose bind-mount accident)" >&2
    echo "             Removing the empty directory so the bind-mount can attach a real file next recreate." >&2
    if rmdir "$CRED_PATH" 2>/dev/null; then
      touch "$CRED_PATH"
    else
      echo "praxis-up: ERROR — directory at $CRED_PATH is not empty; refusing to delete blindly." >&2
      echo "             Inspect contents and either preserve them under a backup name or delete manually." >&2
      exit 3
    fi
  elif [[ ! -e "$CRED_PATH" ]]; then
    touch "$CRED_PATH"
  fi

  echo "→ exporting Keychain (account=praxis) into shell env via bin/praxis-compose-env"
  # shellcheck disable=SC2046
  set -a
  eval "$("$COMPOSE_ENV_BIN")"
  set +a

  echo "→ docker compose up -d --force-recreate ${SERVICES[*]}"
  docker compose up -d --force-recreate "${SERVICES[@]}"

  if service_selected api-server; then
    echo "→ waiting for the api-server service to come back online..."
    for _ in $(seq 1 30); do
      if docker compose exec -T api-server python3 -c "print(1)" >/dev/null 2>&1; then
        break
      fi
      sleep 1
    done
  fi

  if service_selected agent-broker; then
    echo "→ waiting for the agent-broker service to come back online..."
    for _ in $(seq 1 30); do
      if docker compose exec -T agent-broker python3 -c "print(1)" >/dev/null 2>&1; then
        break
      fi
      sleep 1
    done
  fi
fi

# The worker is control-plane only. Provider CLI auth lives in provider-family
# thin images and credential authority, so worker health must not depend on
# Claude/Codex/Gemini auth state.
if [[ $VERIFY_ONLY -eq 0 ]] && ! service_selected workflow-worker; then
  echo "→ skipping workflow-worker liveness check (workflow-worker was not requested)"
  exit 0
fi

echo "→ checking workflow-worker control-plane liveness"
if ! docker compose exec -T workflow-worker python3 - <<'PY'
from runtime.workflow import _worker_loop
print("worker-control-plane-ok")
PY
then
  echo "praxis-up: workflow-worker liveness check failed." >&2
  exit 1
fi

echo "✓ workflow-worker control plane healthy."
