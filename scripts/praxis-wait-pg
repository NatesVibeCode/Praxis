#!/usr/bin/env bash
# Waits for postgres to accept connections, then exec's the given command.
# Used as a wrapper in launchd plists so workers don't crash-loop on boot
# while postgres is still starting up.

tries=0
workflow_database_url="${WORKFLOW_DATABASE_URL:?"WORKFLOW_DATABASE_URL must be set"}"
authorityless="${workflow_database_url#*://}"
path_part="${authorityless#*/}"
database_name="${path_part%%\?*}"
database_name="${database_name%%#*}"
if [ -z "$database_name" ] || [ "$database_name" = "$authorityless" ]; then
    database_name="praxis"
fi

while ! pg_isready -h 127.0.0.1 -p 5432 -d "$database_name" -q 2>/dev/null; do
    tries=$((tries + 1))
    if [ $tries -ge 60 ]; then
        echo "praxis-wait-pg: postgres not ready after 60s, starting anyway" >&2
        break
    fi
    sleep 1
done

exec "$@"
