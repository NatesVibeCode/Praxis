    },
    {
      "label": "step2_echo",
      "agent": "anthropic/claude-sonnet-4-6",
      "depends_on": [
        "step1_echo"
      ],
      "prompt": "Reply with exactly: STEP2_OK",
      "timeout": 180
    }
  ]
}
