{
  "name": "praxis-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json && node ./scripts/clean-dist.mjs && node ./node_modules/vite/bin/vite.js build --emptyOutDir=false",
    "test": "node ./node_modules/vitest/vitest.mjs run --bail=1",
    "test:all": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
