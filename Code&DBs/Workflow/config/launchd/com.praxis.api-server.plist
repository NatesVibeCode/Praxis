<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.praxis.api-server</string>
	<key>Program</key>
	<string>python3</string>
	<key>ProgramArguments</key>
	<array>
		<string>python3</string>
		<string>-m</string>
		<string>surfaces.api.server</string>
		<string>--host</string>
		<string>127.0.0.1</string>
		<string>--port</string>
		<string>8420</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Users/nate/Praxis/Code&DBs/Workflow</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PYTHONPATH</key>
		<string>/Users/nate/Praxis/Code&DBs/Workflow</string>
		<key>WORKFLOW_DATABASE_URL</key>
		<string>postgresql://localhost:5432/praxis</string>
	</dict>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/tmp/praxis-api-server.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/praxis-api-server.err</string>
	<key>RunAtLoad</key>
	<true/>
	<key>ProcessType</key>
	<string>Background</string>
</dict>
</plist>
