#!/usr/bin/env bash
# praxis-agent — canonical agent dispatcher for Praxis (broker-front-door).
#
# This is THE one front door for Claude Code and any other Mac-host agent
# that operates against Praxis. It bypasses host-shell pollution
# (CLAUDECODE nested-session guard, macOS Gatekeeper / Claude.app disclaimer
# wrapper on unsigned Python) by POSTing to the local praxis-agentd broker,
# which dispatches through the canonical MCP/CQRS path
# (handle_request → invoke_tool → operation_catalog_gateway) inside the
# credentialed Docker runtime.
#
# Why broker, not api-server:
#   The previous implementation POSTed to http://localhost:8420/mcp on the
#   api-server, which:
#     1. Required PRAXIS_API_TOKEN to be read via `docker exec` per call,
#     2. Forced workflow-worker MCP traffic to depend on api-server health,
#     3. Tied "the API got stuck" directly to "every CLI agent wedged".
#   praxis-agentd is a separate, long-lived broker process whose only job is
#   to be the local front door for CLI/MCP traffic. The api-server stays
#   for human-facing surfaces (Moon, REST API).
#
# Why not docker exec python3:
#   An earlier implementation spawned `docker exec praxis-api-server-1
#   python3 -` per call. Each spawn created its own asyncpg pool with
#   min_size=1 and exited without shutdown_workflow_pool(), leaking one
#   idle Postgres connection per call (BUG-D7A939CA). Postgres saturates
#   at max_connections (100 by default), blocking every gateway op.
#
# Standing-order references:
#   architecture-policy::auth::via-docker-creds-not-shell
#   architecture-policy::surfaces::cli-mcp-parallel
#
# Usage:
#   praxis-agent <tool_name> --input-json '{...}'
#   praxis-agent <tool_name> --input-file <path>
#   praxis-agent --list
#   praxis-agent --describe <tool_name>
#
# Examples:
#   praxis-agent praxis_compose_and_launch --input-json '{
#     "approved_by": "nate@praxis",
#     "plan_name": "audit_x",
#     "intent": "1. Audit X.\n2. Audit Y."
#   }'
#   praxis-agent praxis_search --input-json '{"query": "provider routing"}'
#
# Returns: tool result as JSON on stdout. Non-zero exit on dispatch error.
#
# Configuration:
#   PRAXIS_AGENT_BROKER_URL       (default: http://127.0.0.1:8422/rpc)
#   PRAXIS_AGENT_BROKER_STATE_DIR (default: <repo>/artifacts/agent-broker)
#   PRAXIS_AGENT_BROKER_TOKEN_FILE
#                                 (default: $STATE_DIR/token)
#   PRAXIS_AGENT_BROKER_SOCKET    optional UDS path; if set + present, used
#                                 instead of the loopback HTTP URL.
#
# Operator notes:
#   - If the broker token/state file is missing, this script exits 3 with
#     a hint to run `scripts/praxis-up agent-broker`.
#   - This script never falls back to the api-server, never reads host
#     provider env vars, and never invokes `docker exec`.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

DEFAULT_STATE_DIR="${REPO_ROOT}/artifacts/agent-broker"
STATE_DIR="${PRAXIS_AGENT_BROKER_STATE_DIR:-$DEFAULT_STATE_DIR}"
URL="${PRAXIS_AGENT_BROKER_URL:-http://127.0.0.1:8422/rpc}"
TOKEN_FILE="${PRAXIS_AGENT_BROKER_TOKEN_FILE:-$STATE_DIR/token}"
SOCKET="${PRAXIS_AGENT_BROKER_SOCKET:-}"

usage() {
  cat <<'USAGE'
praxis-agent — canonical agent dispatcher (HTTP → praxis-agentd → operation_catalog_gateway)

Usage:
  praxis-agent <tool_name> --input-json '{...}'
  praxis-agent <tool_name> --input-file <path>
  praxis-agent --list
  praxis-agent --describe <tool_name>
  praxis-agent --help

Environment:
  PRAXIS_AGENT_BROKER_URL       Broker /rpc endpoint (default: http://127.0.0.1:8422/rpc).
  PRAXIS_AGENT_BROKER_STATE_DIR Directory containing the broker token (default: <repo>/artifacts/agent-broker).
  PRAXIS_AGENT_BROKER_TOKEN_FILE
                                Override the token file path (default: $STATE_DIR/token).
  PRAXIS_AGENT_BROKER_SOCKET    Optional UDS path; if set + present, takes precedence over BROKER_URL.
USAGE
}

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 2
fi

case "$1" in
  -h|--help)
    usage
    exit 0
    ;;
esac

# Read the broker token. The broker writes it at boot to $STATE_DIR/token,
# which is the same path inside the container (mounted via the workspace
# volume) and on the host. No `docker exec`; no host env inheritance.
if [[ ! -f "$TOKEN_FILE" ]]; then
  cat >&2 <<EOF
praxis-agent: broker token file not found at $TOKEN_FILE.

The praxis-agentd broker is not running, or its state directory is not
mounted. Start (or recreate) the broker with:

    scripts/praxis-up agent-broker

If you've moved the state directory, set PRAXIS_AGENT_BROKER_STATE_DIR or
PRAXIS_AGENT_BROKER_TOKEN_FILE.
EOF
  exit 3
fi

TOKEN="$(tr -d '\n' < "$TOKEN_FILE")"
if [[ -z "$TOKEN" ]]; then
  echo "praxis-agent: broker token file is empty: $TOKEN_FILE" >&2
  exit 4
fi

# _post_jsonrpc <method> <params_json>
# Sends a JSON-RPC 2.0 request to the broker and prints the inner result on
# stdout, or the error envelope on stderr (and exits non-zero).
_post_jsonrpc() {
  local method="$1"
  local params="$2"
  local body
  body=$(printf '{"jsonrpc":"2.0","id":1,"method":"%s","params":%s}' "$method" "$params")

  local response http_status curl_args
  if [[ -n "$SOCKET" && -S "$SOCKET" ]]; then
    curl_args=(--unix-socket "$SOCKET" "http://localhost/rpc")
  else
    curl_args=("$URL")
  fi
  response=$(curl -sS -w '\n%{http_code}' -X POST "${curl_args[@]}" \
    -H "Authorization: Bearer $TOKEN" \
    -H "Content-Type: application/json" \
    --data-binary "$body") || {
    echo "praxis-agent: HTTP request to broker failed (${curl_args[*]})" >&2
    exit 5
  }
  http_status="${response##*$'\n'}"
  body="${response%$'\n'*}"

  if [[ "$http_status" != "200" && "$http_status" != "202" ]]; then
    echo "praxis-agent: HTTP $http_status from broker" >&2
    echo "$body" >&2
    exit 6
  fi
  printf '%s' "$body"
}

case "$1" in
  --list)
    response=$(_post_jsonrpc "tools/list" "{}")
    echo "$response" | python3 -c '
import json, sys
d = json.load(sys.stdin)
err = d.get("error")
if err:
    sys.stderr.write("praxis-agent: tools/list error: " + json.dumps(err) + "\n")
    sys.exit(1)
tools = (d.get("result") or {}).get("tools") or []
for t in sorted(tools, key=lambda x: x.get("name") or ""):
    name = t.get("name") or ""
    desc = (t.get("description") or "").splitlines()[0][:90]
    print(name + "\t" + desc)
'
    exit 0
    ;;
  --describe)
    if [[ $# -lt 2 ]]; then
      echo "praxis-agent: --describe requires a tool name" >&2
      exit 2
    fi
    target="$2"
    response=$(_post_jsonrpc "tools/list" "{}")
    echo "$response" | python3 -c "
import json, sys
d = json.load(sys.stdin)
if d.get('error'):
    print(f'praxis-agent: tools/list error: {d[\"error\"]}', file=sys.stderr); sys.exit(1)
tools = (d.get('result') or {}).get('tools') or []
target = '$target'
for t in tools:
    if t.get('name') == target:
        out = {
            'name': t.get('name'),
            'description': t.get('description') or '',
            'input_schema': t.get('inputSchema'),
            'badges': list(t.get('badges') or []),
        }
        print(json.dumps(out, indent=2, default=str))
        sys.exit(0)
print(json.dumps({'ok': False, 'error': f'tool not found: {target}'}), file=sys.stderr)
sys.exit(1)
"
    exit 0
    ;;
esac

TOOL_NAME="$1"
shift

PAYLOAD=""
if [[ $# -lt 2 ]]; then
  echo "praxis-agent: expected --input-json '{...}' or --input-file <path> after tool name" >&2
  exit 2
fi

case "$1" in
  --input-json)
    PAYLOAD="$2"
    ;;
  --input-file)
    if [[ ! -f "$2" ]]; then
      echo "praxis-agent: --input-file path does not exist: $2" >&2
      exit 2
    fi
    PAYLOAD="$(cat "$2")"
    ;;
  *)
    echo "praxis-agent: expected --input-json or --input-file, got: $1" >&2
    exit 2
    ;;
esac

# Sanity-check JSON before paying the round-trip.
if ! python3 -c "import json,sys; json.loads(sys.argv[1])" "$PAYLOAD" 2>/dev/null; then
  echo "praxis-agent: --input-json must be valid JSON" >&2
  exit 2
fi

# Build params for tools/call. Use python3 to safely embed PAYLOAD as
# JSON inside the JSON-RPC envelope (handles quotes, newlines, etc).
PARAMS=$(python3 -c "
import json, sys
args = json.loads(sys.argv[1])
print(json.dumps({'name': sys.argv[2], 'arguments': args}))
" "$PAYLOAD" "$TOOL_NAME")

response=$(_post_jsonrpc "tools/call" "$PARAMS")

# Unwrap MCP envelope. The tool result is JSON-encoded in
# result.content[0].text by handle_tools_call (surfaces/mcp/protocol.py).
echo "$response" | python3 -c '
import json, sys
d = json.load(sys.stdin)
err = d.get("error")
if err:
    sys.stderr.write(json.dumps({"ok": False, "error": err}) + "\n")
    sys.exit(1)
result = d.get("result") or {}
content = result.get("content") or []
if content and isinstance(content[0], dict) and "text" in content[0]:
    # The tool result is JSON-encoded by _serialize_tool_result.
    print(content[0]["text"])
else:
    print(json.dumps(result, default=str))
'
