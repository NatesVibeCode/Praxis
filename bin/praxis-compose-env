#!/usr/bin/env bash
# praxis-compose-env — export macOS Keychain secrets as shell env lines so
# docker-compose can pass them into long-lived control containers
# (api-server, scheduler, workflow-worker) that run the MCP bridge,
# integration dispatch paths, and CLI-backed providers.
#
# Usage:
#   eval "$(bin/praxis-compose-env)"
#   docker compose up -d --force-recreate api-server scheduler
#
# Or piped into docker compose --env-file:
#   compose_env="$(mktemp -t praxis-compose.XXXXXX)"
#   bin/praxis-compose-env --dotenv > "$compose_env"
#   docker compose --env-file "$compose_env" up -d
#
# Why this exists: integration manifests declare env_var-backed auth. The
# resolve_secret() chain in adapters/keychain.py checks .env → Keychain →
# os.environ, but inside a Linux container only .env and os.environ are
# reachable. Keychain-first policy forbids plaintext in .env, so the
# container must get the secret via os.environ — set at compose-up by
# this script from the host Keychain.
#
# This is the authorized Keychain→container bridge. See
# architecture-policy::providers::provider-auth-mode-single-authority for
# the broader single-auth-rail principle.

set -euo pipefail

emit_mode="shell"
if [[ "${1:-}" == "--dotenv" ]]; then
  emit_mode="dotenv"
fi

if ! command -v security >/dev/null 2>&1; then
  echo "praxis-compose-env: 'security' CLI not found — macOS Keychain required" >&2
  exit 2
fi

# Enumerate services under account="praxis". dump-keychain prints entries
# as multi-line blocks separated by "keychain:" headers; svce and acct
# can appear in either order within a block, so collect both per-entry
# and emit only when acct == "praxis".
services=$(security dump-keychain 2>/dev/null \
  | awk '
      function flush() {
        if (svce != "" && acct == "praxis") print svce
        svce=""; acct=""
      }
      /^keychain:/ { flush() }
      /"svce"<blob>=/ {
        line=$0
        sub(/.*"svce"<blob>="/, "", line)
        sub(/"$/, "", line)
        svce=line
      }
      /"acct"<blob>=/ {
        line=$0
        sub(/.*"acct"<blob>="/, "", line)
        sub(/"$/, "", line)
        acct=line
      }
      END { flush() }
    ' \
  | sort -u)

if [[ -z "$services" ]]; then
  echo "praxis-compose-env: no Keychain entries for account='praxis'" >&2
  exit 3
fi

while IFS= read -r name; do
  # Only hydrate things that look like env-var names (uppercase + underscore
  # + digits). Skip noisy entries.
  if [[ ! "$name" =~ ^[A-Z][A-Z0-9_]*$ ]]; then
    continue
  fi
  value=$(security find-generic-password -a praxis -s "$name" -w 2>/dev/null || true)
  if [[ -z "$value" ]]; then
    continue
  fi
  case "$emit_mode" in
    shell)
      # export NAME='value'  (single-quote escape any interior ')
      printf "export %s=%s\n" "$name" "$(printf '%s' "$value" | sed "s/'/'\\\\''/g; s/^/'/; s/\$/'/")"
      ;;
    dotenv)
      printf "%s=%s\n" "$name" "$value"
      ;;
  esac
done <<< "$services"

# Claude Code OAuth on macOS lives in Anthropic's own Keychain item rather
# than under account="praxis". Export it explicitly so noninteractive Linux
# containers can authenticate via CLAUDE_CODE_OAUTH_TOKEN instead of a
# file-backed ~/.claude/.credentials.json path that only exists on Linux.
claude_oauth_json="$(security find-generic-password -s 'Claude Code-credentials' -w 2>/dev/null || true)"
if [[ -n "$claude_oauth_json" ]]; then
  claude_oauth_token="$(
    printf '%s' "$claude_oauth_json" \
      | /usr/bin/python3 -c 'import json, sys; print(json.load(sys.stdin).get("claudeAiOauth", {}).get("accessToken", ""))' \
        2>/dev/null || true
  )"
  if [[ -n "$claude_oauth_token" ]]; then
    case "$emit_mode" in
      shell)
        printf "export %s=%s\n" "CLAUDE_CODE_OAUTH_TOKEN" "$(printf '%s' "$claude_oauth_token" | sed "s/'/'\\\\''/g; s/^/'/; s/\$/'/")"
        ;;
      dotenv)
        printf "%s=%s\n" "CLAUDE_CODE_OAUTH_TOKEN" "$claude_oauth_token"
        ;;
    esac
  fi
fi
