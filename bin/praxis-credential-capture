#!/usr/bin/env python3
"""Host CLI fallback for secure Praxis credential capture."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "Code&DBs" / "Workflow"))

from adapters.credential_capture import capture_api_key_to_keychain  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Capture an API key into macOS Keychain.")
    parser.add_argument("env_var_name")
    parser.add_argument("--label", default="provider")
    args = parser.parse_args()

    result = capture_api_key_to_keychain(
        args.env_var_name,
        provider_label=args.label,
    )
    print(json.dumps(result.to_redacted_dict(), indent=2, sort_keys=True))
    return 0 if result.status == "ok" else 1


if __name__ == "__main__":
    raise SystemExit(main())
